# Server environment variables for Esteban
# Copy this file to .env and fill in your local values.

# STT (speech-to-text)
ESTEBAN_STT_DEVICE=cpu
ESTEBAN_STT_MODEL=base
ESTEBAN_STT_COMPUTE_TYPE=int8

# Deezer API
DEEZER_API_BASE_URL=https://api.deezer.com
DEEZER_APP_ID=
DEEZER_APP_SECRET=
DEEZER_REDIRECT_URI=
DEEZER_ACCESS_TOKEN=
